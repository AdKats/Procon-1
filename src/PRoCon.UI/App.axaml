<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="PRoCon.UI.App"
             RequestedThemeVariant="Dark">

  <Application.Styles>
    <FluentTheme />

    <!-- ═══════════════════════════════════════════ -->
    <!-- Global Tactical Theme Styles                -->
    <!-- ═══════════════════════════════════════════ -->

    <!-- Monospace font for all TextBlocks -->
    <Style Selector="TextBlock">
      <Setter Property="FontFamily" Value="Consolas, Cascadia Mono, Courier New, monospace" />
    </Style>

    <!-- Monospace font for TextBox -->
    <Style Selector="TextBox">
      <Setter Property="FontFamily" Value="Consolas, Cascadia Mono, Courier New, monospace" />
      <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
      <Setter Property="CornerRadius" Value="{DynamicResource CornerRadiusSmall}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Padding" Value="8,6" />
    </Style>
    <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
      <Setter Property="BorderBrush" Value="{DynamicResource InputFocusBorderBrush}" />
    </Style>
    <Style Selector="TextBox:pointerover /template/ Border#PART_BorderElement">
      <Setter Property="BorderBrush" Value="{DynamicResource BorderBrightBrush}" />
    </Style>
    <Style Selector="TextBox /template/ TextBlock#PART_Watermark">
      <Setter Property="Foreground" Value="{DynamicResource TextDisabledBrush}" />
    </Style>

    <!-- ComboBox styling -->
    <Style Selector="ComboBox">
      <Setter Property="FontFamily" Value="Consolas, Cascadia Mono, Courier New, monospace" />
      <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
      <Setter Property="CornerRadius" Value="{DynamicResource CornerRadiusSmall}" />
    </Style>

    <!-- Button base styling -->
    <Style Selector="Button">
      <Setter Property="FontFamily" Value="Consolas, Cascadia Mono, Courier New, monospace" />
      <Setter Property="CornerRadius" Value="{DynamicResource CornerRadiusSmall}" />
      <Setter Property="Padding" Value="12,6" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Background" Value="{DynamicResource ButtonPrimaryGradient}" />
      <Setter Property="BorderBrush" Value="{DynamicResource ButtonPrimaryBorderBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource ButtonPrimaryTextBrush}" />
    </Style>
    <Style Selector="Button:pointerover">
      <Setter Property="Background" Value="{DynamicResource ButtonPrimaryHoverBrush}" />
    </Style>

    <!-- Button variant classes -->
    <Style Selector="Button.warning">
      <Setter Property="Background" Value="{DynamicResource ButtonWarningGradient}" />
      <Setter Property="BorderBrush" Value="{DynamicResource ButtonWarningBorderBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource ButtonWarningTextBrush}" />
    </Style>
    <Style Selector="Button.danger">
      <Setter Property="Background" Value="{DynamicResource ButtonDangerGradient}" />
      <Setter Property="BorderBrush" Value="{DynamicResource ButtonDangerBorderBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource ButtonDangerTextBrush}" />
    </Style>
    <Style Selector="Button.secondary">
      <Setter Property="Background" Value="{DynamicResource ButtonSecondaryBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource ButtonSecondaryBorderBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource ButtonSecondaryTextBrush}" />
    </Style>

    <!-- Glass Panel class -->
    <Style Selector="Border.glass-panel">
      <Setter Property="Background" Value="{DynamicResource GlassPanelBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource GlassBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="{DynamicResource CornerRadius}" />
      <Setter Property="BoxShadow" Value="0 4 20 0 #66000000" />
    </Style>

    <!-- Glass Header class -->
    <Style Selector="Border.glass-header">
      <Setter Property="Background" Value="{DynamicResource GlassHeaderBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
      <Setter Property="BorderThickness" Value="0,0,0,1" />
      <Setter Property="Padding" Value="12,8" />
    </Style>

    <!-- Section label style (uppercase monospace with letter-spacing) -->
    <Style Selector="TextBlock.section-label">
      <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}" />
      <Setter Property="FontSize" Value="10" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="LetterSpacing" Value="3" />
    </Style>

    <!-- Dim label style -->
    <Style Selector="TextBlock.dim-label">
      <Setter Property="Foreground" Value="{DynamicResource TextDisabledBrush}" />
      <Setter Property="FontSize" Value="9" />
      <Setter Property="LetterSpacing" Value="2" />
    </Style>

    <!-- Data value styles -->
    <Style Selector="TextBlock.data-value">
      <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
      <Setter Property="FontSize" Value="11" />
    </Style>

    <!-- CheckBox styling -->
    <Style Selector="CheckBox">
      <Setter Property="FontFamily" Value="Consolas, Cascadia Mono, Courier New, monospace" />
      <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>

    <!-- ListBox styling -->
    <Style Selector="ListBox">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
    </Style>
    <Style Selector="ListBoxItem">
      <Setter Property="Padding" Value="8,6" />
    </Style>
    <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource RowHoverBrush}" />
    </Style>
    <Style Selector="ListBoxItem:selected /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource RowSelectedBrush}" />
    </Style>

    <!-- NumericUpDown styling -->
    <Style Selector="NumericUpDown">
      <Setter Property="FontFamily" Value="Consolas, Cascadia Mono, Courier New, monospace" />
      <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>

    <!-- ScrollViewer thumb -->
    <Style Selector="ScrollBar /template/ Thumb">
      <Setter Property="Background" Value="{DynamicResource ScrollBarThumbBrush}" />
    </Style>

    <!-- ═══════════════════════════════════════════ -->
    <!-- Animation styles                            -->
    <!-- ═══════════════════════════════════════════ -->

    <!-- Pulsing status dot (connected servers) -->
    <Style Selector="Ellipse.pulse-dot">
      <Style.Animations>
        <Animation Duration="0:0:2" IterationCount="Infinite" PlaybackDirection="Alternate">
          <KeyFrame Cue="0%">
            <Setter Property="Opacity" Value="0.6" />
          </KeyFrame>
          <KeyFrame Cue="100%">
            <Setter Property="Opacity" Value="1.0" />
          </KeyFrame>
        </Animation>
      </Style.Animations>
    </Style>

    <!-- Ripple ring (landing page) — opacity + size expansion -->
    <Style Selector="Ellipse.ripple-ring">
      <Style.Animations>
        <Animation Duration="0:0:2" IterationCount="Infinite" Easing="CubicEaseOut">
          <KeyFrame Cue="0%">
            <Setter Property="Opacity" Value="0.6" />
            <Setter Property="Width" Value="40" />
            <Setter Property="Height" Value="40" />
          </KeyFrame>
          <KeyFrame Cue="100%">
            <Setter Property="Opacity" Value="0" />
            <Setter Property="Width" Value="80" />
            <Setter Property="Height" Value="80" />
          </KeyFrame>
        </Animation>
      </Style.Animations>
    </Style>

    <!-- Glass panel hover glow -->
    <Style Selector="Border.glass-panel:pointerover">
      <Setter Property="BorderBrush" Value="{DynamicResource BorderBrightBrush}" />
    </Style>

    <!-- Panel fade-in on load (opacity only — RenderTransform can't be keyframed) -->
    <Style Selector="Border.fade-in">
      <Style.Animations>
        <Animation Duration="0:0:0.2" Easing="CubicEaseOut" FillMode="Forward">
          <KeyFrame Cue="0%">
            <Setter Property="Opacity" Value="0" />
          </KeyFrame>
          <KeyFrame Cue="100%">
            <Setter Property="Opacity" Value="1" />
          </KeyFrame>
        </Animation>
      </Style.Animations>
    </Style>

    <!-- ═══════════════════════════════════════════ -->
    <!-- No-animations override (when .no-animations  -->
    <!-- class is on the Window)                       -->
    <!-- ═══════════════════════════════════════════ -->
    <Style Selector="Window.no-animations Ellipse.pulse-dot">
      <Setter Property="Opacity" Value="1" />
    </Style>
    <Style Selector="Window.no-animations Ellipse.ripple-ring">
      <Setter Property="Opacity" Value="0" />
    </Style>



  </Application.Styles>

  <Application.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceInclude Source="avares://PRoCon.Themes/Themes/DarkTheme.axaml" />
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </Application.Resources>

</Application>
