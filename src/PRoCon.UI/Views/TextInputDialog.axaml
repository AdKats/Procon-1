<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="PRoCon.UI.Views.TextInputDialog"
        x:CompileBindings="False"
        Title="Input"
        Width="400" Height="200"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundBrush}">

  <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="3" Padding="24" Margin="16">
    <StackPanel Spacing="12">
      <TextBlock Name="PromptText" Text="Enter a value:"
                 FontSize="14" FontWeight="SemiBold"
                 Foreground="{DynamicResource TextPrimaryBrush}" />

      <TextBox Name="InputBox"
               Watermark="Type here..."
               Background="{DynamicResource InputBackgroundBrush}"
               Foreground="{DynamicResource TextPrimaryBrush}"
               BorderBrush="{DynamicResource BorderBrush}" />

      <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" Margin="0,4,0,0">
        <Button Content="Cancel"
                Background="{DynamicResource ButtonSecondaryBrush}"
                Foreground="{DynamicResource ButtonSecondaryTextBrush}"
                Padding="16,8" CornerRadius="4"
                Click="OnCancel" />
        <Button Content="OK"
                Background="{DynamicResource ButtonPrimaryBrush}"
                Foreground="{DynamicResource ButtonPrimaryTextBrush}"
                Padding="16,8" CornerRadius="4"
                Click="OnOK" />
      </StackPanel>
    </StackPanel>
  </Border>
</Window>
