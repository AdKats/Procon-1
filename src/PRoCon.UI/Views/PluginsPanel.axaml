<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="PRoCon.UI.Views.PluginsPanel"
             x:CompileBindings="False">

  <DockPanel>
    <!-- Security warning -->
    <Border DockPanel.Dock="Top" Background="#3d2200" CornerRadius="6" Padding="12" Margin="0,0,0,8">
      <TextBlock Text="Plugins run with full trust on .NET 8. Only install plugins from trusted sources."
                 Foreground="#ffab40" FontSize="12" TextWrapping="Wrap" />
    </Border>

  <Grid RowDefinitions="*,Auto">

  <Grid Grid.Row="0" ColumnDefinitions="280,*">

    <!-- Left: Plugin List -->
    <Border Grid.Column="0"
            Background="{DynamicResource SurfaceBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="0,0,1,0">
      <DockPanel>
        <TextBlock DockPanel.Dock="Top" Text="Plugins" FontSize="16" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextPrimaryBrush}" Margin="12,12,12,8" />

        <Button DockPanel.Dock="Bottom" Content="Reload Plugins" Margin="12,8"
                Background="{DynamicResource ButtonSecondaryBrush}"
                Foreground="{DynamicResource ButtonSecondaryTextBrush}"
                HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                Padding="8,6" CornerRadius="4"
                Click="OnReloadPlugins" />

        <ListBox Name="PluginListBox" Background="Transparent" Margin="4,0"
                 SelectionChanged="OnPluginSelected">
          <ListBox.ItemTemplate>
            <DataTemplate>
              <Border Padding="8,6" CornerRadius="4" Margin="2">
                <Grid ColumnDefinitions="Auto,*,Auto">
                  <Ellipse Grid.Column="0" Width="8" Height="8" Fill="{Binding StatusColor}"
                           VerticalAlignment="Center" Margin="0,0,8,0" />
                  <StackPanel Grid.Column="1" Spacing="2" Margin="0,0,8,0">
                    <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" FontSize="13"
                               TextWrapping="Wrap" TextTrimming="None" />
                    <TextBlock Text="{Binding InfoLine}" FontSize="11"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               TextWrapping="Wrap" TextTrimming="None" />
                  </StackPanel>
                  <ToggleButton Grid.Column="2"
                                IsChecked="{Binding IsEnabled}"
                                Content="{Binding EnabledText}"
                                Background="{Binding StatusColor}"
                                Foreground="#ffffff"
                                Padding="8,4" FontSize="11" FontWeight="SemiBold"
                                CornerRadius="4" MinWidth="40"
                                HorizontalContentAlignment="Center"
                                VerticalAlignment="Center"
                                Click="OnTogglePlugin" />
                </Grid>
              </Border>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </DockPanel>
    </Border>

    <!-- Right: Plugin Details with Tabs -->
    <DockPanel Grid.Column="1">

      <!-- Plugin Header -->
      <Border DockPanel.Dock="Top"
              Background="{DynamicResource SurfaceBrush}"
              Padding="16,12" Margin="0,0,0,0"
              BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
        <DockPanel>
          <StackPanel DockPanel.Dock="Right" VerticalAlignment="Center">
            <TextBlock Name="DetailVersionText" Foreground="{DynamicResource TextSecondaryBrush}"
                       FontSize="11" HorizontalAlignment="Right" />
            <TextBlock Name="DetailAuthorText" Foreground="{DynamicResource TextSecondaryBrush}"
                       FontSize="11" HorizontalAlignment="Right" />
          </StackPanel>
          <TextBlock Name="DetailNameText" Text="Select a plugin" FontSize="18" FontWeight="Bold"
                     Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center" />
        </DockPanel>
      </Border>

      <!-- Tab Control: Description / Settings -->
      <TabControl Name="PluginTabControl" Margin="0"
                  Background="{DynamicResource SurfaceBrush}">

        <!-- Description Tab -->
        <TabItem Header="Description" FontSize="13">
          <ScrollViewer Padding="16">
            <StackPanel Name="DescriptionPanel" Spacing="4" />
          </ScrollViewer>
        </TabItem>

        <!-- Settings Tab -->
        <TabItem Header="Settings" FontSize="13">
          <ListBox Name="VariablesItemsControl"
                   Background="Transparent" Margin="8"
                   ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                   ScrollViewer.VerticalScrollBarVisibility="Auto">
            <ListBox.ItemTemplate>
              <DataTemplate>
                <Panel>
                  <!-- Group header row -->
                  <TextBlock Text="{Binding Name}" IsVisible="{Binding IsHeader}"
                             Foreground="{DynamicResource SecondaryBrush}"
                             FontSize="12" FontWeight="Bold"
                             Margin="0,12,0,4" />

                  <!-- Variable row -->
                <Grid ColumnDefinitions="220,*" Margin="0,3" IsVisible="{Binding IsNotHeader}">
                  <TextBlock Grid.Column="0" Text="{Binding Name}" VerticalAlignment="Top"
                             Foreground="{DynamicResource TextPrimaryBrush}" FontSize="12"
                             TextWrapping="Wrap" Margin="0,6,12,0" />

                  <!-- Dropdown for bool/onoff/yesno/enum types -->
                  <ComboBox Grid.Column="1"
                            ItemsSource="{Binding DropdownOptions}"
                            SelectedItem="{Binding Value}"
                            IsVisible="{Binding IsDropdown}"
                            IsEnabled="{Binding !IsReadOnly}"
                            Background="{DynamicResource InputBackgroundBrush}"
                            Foreground="{DynamicResource TextPrimaryBrush}"
                            FontSize="12" Padding="6,4"
                            HorizontalAlignment="Stretch"
                            SelectionChanged="OnDropdownChanged" />

                  <!-- Multiline TextBox for multiline/stringarray types -->
                  <TextBox Grid.Column="1" Text="{Binding Value}"
                           IsVisible="{Binding IsMultiline}"
                           Background="{DynamicResource InputBackgroundBrush}"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           BorderBrush="{DynamicResource BorderBrush}"
                           FontSize="12" Padding="8,6"
                           AcceptsReturn="True" TextWrapping="Wrap"
                           MinHeight="80" MaxHeight="250"
                           IsReadOnly="{Binding IsReadOnly}"
                           LostFocus="OnVariableValueChanged" />

                  <!-- Single-line TextBox for int/double/string types -->
                  <TextBox Grid.Column="1" Text="{Binding Value}"
                           IsVisible="{Binding IsTextBox}"
                           Background="{DynamicResource InputBackgroundBrush}"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           BorderBrush="{DynamicResource BorderBrush}"
                           FontSize="12" Padding="8,6"
                           IsReadOnly="{Binding IsReadOnly}"
                           LostFocus="OnVariableValueChanged" />
                </Grid>
                </Panel>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </TabItem>

      </TabControl>

    </DockPanel>
  </Grid>

    <!-- Plugin Output Console -->
    <Border Grid.Row="1"
            Background="{DynamicResource SurfaceBrush}"
            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0">
      <DockPanel>
        <Border DockPanel.Dock="Top" Padding="8,6"
                Background="{DynamicResource SurfaceElevatedBrush}">
          <DockPanel>
            <TextBlock Text="Plugin Output" FontSize="12" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center" />
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="6">
              <Button Name="BtnCopyOutput" Content="Copy" Padding="8,3" FontSize="11"
                      CornerRadius="3"
                      Background="{DynamicResource ButtonSecondaryBrush}"
                      Foreground="{DynamicResource ButtonSecondaryTextBrush}"
                      Click="OnCopyOutput" />
              <Button Name="BtnClearOutput" Content="Clear" Padding="8,3" FontSize="11"
                      CornerRadius="3"
                      Background="{DynamicResource ButtonSecondaryBrush}"
                      Foreground="{DynamicResource ButtonSecondaryTextBrush}"
                      Click="OnClearOutput" />
              <Button Name="BtnToggleOutput" Content="Hide" Padding="8,3" FontSize="11"
                      CornerRadius="3"
                      Background="{DynamicResource ButtonSecondaryBrush}"
                      Foreground="{DynamicResource ButtonSecondaryTextBrush}"
                      Click="OnToggleOutput" />
            </StackPanel>
          </DockPanel>
        </Border>

        <TextBox Name="PluginOutputText"
                 FontFamily="Cascadia Mono,Consolas,Courier New,monospace"
                 FontSize="11" Padding="8,4" Height="160"
                 TextWrapping="Wrap" AcceptsReturn="True"
                 IsReadOnly="True"
                 Background="Transparent"
                 BorderThickness="0"
                 Foreground="{DynamicResource TextSecondaryBrush}" />
      </DockPanel>
    </Border>

  </Grid>

  </DockPanel>

</UserControl>
