<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="PRoCon.UI.Views.PluginsPanel"
             x:CompileBindings="False">

  <DockPanel>
    <!-- Security warning -->
    <Border DockPanel.Dock="Top" Background="#3d2200" CornerRadius="6" Padding="12" Margin="0,0,0,8">
      <TextBlock Text="Plugins run with full trust on .NET 8. Only install plugins from trusted sources."
                 Foreground="#ffab40" FontSize="12" TextWrapping="Wrap" />
    </Border>

  <Grid RowDefinitions="*,Auto">

  <Grid Grid.Row="0" ColumnDefinitions="280,*">

    <!-- Left: Plugin List -->
    <Border Grid.Column="0"
            Background="{DynamicResource SurfaceBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="0,0,1,0">
      <DockPanel>
        <TextBlock DockPanel.Dock="Top" Text="Plugins" FontSize="16" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextPrimaryBrush}" Margin="12,12,12,8" />

        <Button DockPanel.Dock="Bottom" Content="Reload Plugins" Margin="12,8"
                Background="{DynamicResource ButtonSecondaryBrush}"
                Foreground="{DynamicResource ButtonSecondaryTextBrush}"
                HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                Padding="8,6" CornerRadius="4"
                Click="OnReloadPlugins" />

        <ListBox Name="PluginListBox" Background="Transparent" Margin="4,0"
                 SelectionChanged="OnPluginSelected">
          <ListBox.ItemTemplate>
            <DataTemplate>
              <Border Padding="8,6" CornerRadius="4" Margin="2">
                <DockPanel>
                  <ToggleButton DockPanel.Dock="Right"
                                IsChecked="{Binding IsEnabled}"
                                Content="{Binding EnabledText}"
                                Padding="8,4" FontSize="11" CornerRadius="4"
                                Click="OnTogglePlugin" />
                  <StackPanel Spacing="2">
                    <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" FontSize="13" />
                    <TextBlock Text="{Binding InfoLine}" FontSize="11"
                               Foreground="{DynamicResource TextSecondaryBrush}" />
                  </StackPanel>
                </DockPanel>
              </Border>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </DockPanel>
    </Border>

    <!-- Right: Plugin Details + Variables -->
    <DockPanel Grid.Column="1" Margin="16">

      <!-- Plugin Details Header -->
      <Border DockPanel.Dock="Top"
              Background="{DynamicResource SurfaceBrush}"
              CornerRadius="8" Padding="16" Margin="0,0,0,12"
              BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
        <StackPanel Spacing="8">
          <TextBlock Name="DetailNameText" Text="Select a plugin" FontSize="18" FontWeight="Bold"
                     Foreground="{DynamicResource TextPrimaryBrush}" />
          <StackPanel Orientation="Horizontal" Spacing="16">
            <TextBlock Name="DetailVersionText" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" />
            <TextBlock Name="DetailAuthorText" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" />
          </StackPanel>
          <TextBlock Name="DetailDescriptionText" TextWrapping="Wrap"
                     Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"
                     MaxHeight="120" />
        </StackPanel>
      </Border>

      <!-- Plugin Variables Editor -->
      <Border Background="{DynamicResource SurfaceBrush}"
              CornerRadius="8" Padding="16"
              BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
        <DockPanel>
          <TextBlock DockPanel.Dock="Top" Text="Plugin Variables" FontSize="14" FontWeight="SemiBold"
                     Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,8" />

          <ScrollViewer>
            <ItemsControl Name="VariablesItemsControl">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Grid ColumnDefinitions="200,*" Margin="0,2">
                    <TextBlock Grid.Column="0" Text="{Binding Name}" VerticalAlignment="Center"
                               Foreground="{DynamicResource TextPrimaryBrush}" FontSize="12"
                               Margin="0,0,8,0" />
                    <TextBox Grid.Column="1" Text="{Binding Value}"
                             Background="{DynamicResource InputBackgroundBrush}"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             BorderBrush="{DynamicResource BorderBrush}"
                             FontSize="12" Padding="6,4"
                             IsReadOnly="{Binding IsReadOnly}"
                             LostFocus="OnVariableValueChanged" />
                  </Grid>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </DockPanel>
      </Border>

    </DockPanel>
  </Grid>

    <!-- Plugin Output Console -->
    <Border Grid.Row="1"
            Background="{DynamicResource SurfaceBrush}"
            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0">
      <DockPanel>
        <Border DockPanel.Dock="Top" Padding="8,6"
                Background="{DynamicResource SurfaceElevatedBrush}">
          <DockPanel>
            <TextBlock Text="Plugin Output" FontSize="12" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center" />
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="6">
              <Button Name="BtnClearOutput" Content="Clear" Padding="8,3" FontSize="11"
                      CornerRadius="3"
                      Background="{DynamicResource ButtonSecondaryBrush}"
                      Foreground="{DynamicResource ButtonSecondaryTextBrush}"
                      Click="OnClearOutput" />
              <Button Name="BtnToggleOutput" Content="Hide" Padding="8,3" FontSize="11"
                      CornerRadius="3"
                      Background="{DynamicResource ButtonSecondaryBrush}"
                      Foreground="{DynamicResource ButtonSecondaryTextBrush}"
                      Click="OnToggleOutput" />
            </StackPanel>
          </DockPanel>
        </Border>

        <ScrollViewer Name="OutputScrollViewer" Height="160">
          <TextBlock Name="PluginOutputText"
                     FontFamily="Cascadia Mono,Consolas,Courier New,monospace"
                     FontSize="11" Padding="8,4"
                     TextWrapping="Wrap"
                     Foreground="{DynamicResource TextSecondaryBrush}" />
        </ScrollViewer>
      </DockPanel>
    </Border>

  </Grid>

  </DockPanel>

</UserControl>
