<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="PRoCon.UI.Views.AccountsPanel"
             x:CompileBindings="False">

  <Grid ColumnDefinitions="260,*">

    <!-- Left: Account List -->
    <Border Grid.Column="0"
            Background="{DynamicResource SurfaceBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="0,0,1,0">
      <DockPanel>
        <TextBlock DockPanel.Dock="Top" Text="Accounts" FontSize="16" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextPrimaryBrush}" Margin="12,12,12,4" />
        <TextBlock DockPanel.Dock="Top" Name="AccountCountText" Text="0 accounts"
                   Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" Margin="12,0,12,8" />

        <!-- Add Account Form -->
        <Border DockPanel.Dock="Bottom" Margin="8" Padding="10"
                Background="{DynamicResource BackgroundBrush}" CornerRadius="6">
          <StackPanel Spacing="6">
            <TextBlock Text="Add / Update" FontSize="11" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextSecondaryBrush}" />
            <TextBox Name="AccountUsernameInput" Watermark="Username"
                     Background="{DynamicResource InputBackgroundBrush}"
                     Foreground="{DynamicResource TextPrimaryBrush}"
                     BorderBrush="{DynamicResource BorderBrush}" FontSize="12" Padding="6,4" />
            <TextBox Name="AccountPasswordInput" Watermark="Password" PasswordChar="*"
                     Background="{DynamicResource InputBackgroundBrush}"
                     Foreground="{DynamicResource TextPrimaryBrush}"
                     BorderBrush="{DynamicResource BorderBrush}" FontSize="12" Padding="6,4" />
            <StackPanel Orientation="Horizontal" Spacing="4">
              <Button Content="Add" Padding="10,4" CornerRadius="4" FontSize="11"
                      Background="{DynamicResource ButtonPrimaryBrush}"
                      Foreground="{DynamicResource ButtonPrimaryTextBrush}"
                      Click="OnAddAccount" />
              <Button Content="Remove" Padding="10,4" CornerRadius="4" FontSize="11"
                      Background="{DynamicResource ErrorBrush}" Foreground="#ffffff"
                      Click="OnRemoveAccount" />
              <Button Content="Change Pwd" Padding="10,4" CornerRadius="4" FontSize="11"
                      Background="{DynamicResource ButtonSecondaryBrush}"
                      Foreground="{DynamicResource ButtonSecondaryTextBrush}"
                      Click="OnChangePassword" />
            </StackPanel>
          </StackPanel>
        </Border>

        <ListBox Name="AccountListBox" Background="Transparent" Margin="4,0"
                 SelectionChanged="OnAccountSelected">
          <ListBox.ItemTemplate>
            <DataTemplate>
              <StackPanel Orientation="Horizontal" Spacing="8" Margin="6,4">
                <Ellipse Width="8" Height="8" Fill="{DynamicResource PrimaryBrush}"
                         VerticalAlignment="Center" />
                <TextBlock Text="{Binding Name}" FontSize="13"
                           Foreground="{DynamicResource TextPrimaryBrush}" />
              </StackPanel>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </DockPanel>
    </Border>

    <!-- Right: Privilege Editor -->
    <ScrollViewer Grid.Column="1">
      <StackPanel Margin="16" Spacing="12">
        <DockPanel>
          <TextBlock Name="PrivilegesHeaderText"
                     Text="Select an account to edit privileges"
                     FontSize="18" FontWeight="Bold"
                     Foreground="{DynamicResource TextPrimaryBrush}" DockPanel.Dock="Left" />
        </DockPanel>

        <!-- Quick Presets -->
        <Border Name="PresetsPanel" IsVisible="False"
                Background="{DynamicResource BackgroundBrush}" CornerRadius="8" Padding="12">
          <StackPanel Spacing="6">
            <TextBlock Text="QUICK PRESETS" FontSize="10" FontWeight="Bold"
                       Foreground="{DynamicResource TextSecondaryBrush}" />
            <StackPanel Orientation="Horizontal" Spacing="6">
              <Button Content="Full Admin" Padding="12,5" CornerRadius="4" FontSize="11"
                      Background="{DynamicResource PrimaryBrush}" Foreground="#0f1923"
                      Click="OnPresetFullAdmin" />
              <Button Content="Moderator" Padding="12,5" CornerRadius="4" FontSize="11"
                      Background="{DynamicResource SecondaryBrush}" Foreground="#0f1923"
                      Click="OnPresetModerator" />
              <Button Content="Spectator" Padding="12,5" CornerRadius="4" FontSize="11"
                      Background="{DynamicResource ButtonSecondaryBrush}"
                      Foreground="{DynamicResource ButtonSecondaryTextBrush}"
                      Click="OnPresetSpectator" />
              <Button Content="Clear All" Padding="12,5" CornerRadius="4" FontSize="11"
                      Background="{DynamicResource ErrorBrush}" Foreground="#ffffff"
                      Click="OnPresetClear" />
            </StackPanel>
          </StackPanel>
        </Border>

        <!-- Access -->
        <Border Name="PrivGroupAccess" IsVisible="False"
                Background="{DynamicResource SurfaceBrush}" CornerRadius="8" Padding="14"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
          <StackPanel Spacing="6">
            <TextBlock Text="ACCESS" FontSize="10" FontWeight="Bold"
                       Foreground="{DynamicResource PrimaryBrush}" Margin="0,0,0,4" />
            <CheckBox Name="ChkCanLogin" Content="Can Login"
                      Foreground="{DynamicResource TextPrimaryBrush}" />
            <CheckBox Name="ChkCanAlterServerSettings" Content="Can Alter Server Settings"
                      Foreground="{DynamicResource TextPrimaryBrush}" />
            <CheckBox Name="ChkCanUseMapFunctions" Content="Can Use Map Functions (next map, restart round)"
                      Foreground="{DynamicResource TextPrimaryBrush}" />
            <CheckBox Name="ChkCanShutdownServer" Content="Can Shutdown Server"
                      Foreground="{DynamicResource TextPrimaryBrush}" />
          </StackPanel>
        </Border>

        <!-- Player Management -->
        <Border Name="PrivGroupPlayers" IsVisible="False"
                Background="{DynamicResource SurfaceBrush}" CornerRadius="8" Padding="14"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
          <StackPanel Spacing="6">
            <TextBlock Text="PLAYER MANAGEMENT" FontSize="10" FontWeight="Bold"
                       Foreground="{DynamicResource SecondaryBrush}" Margin="0,0,0,4" />
            <CheckBox Name="ChkCanKillPlayers" Content="Can Kill Players"
                      Foreground="{DynamicResource TextPrimaryBrush}" />
            <CheckBox Name="ChkCanKickPlayers" Content="Can Kick Players"
                      Foreground="{DynamicResource TextPrimaryBrush}" />
            <CheckBox Name="ChkCanMovePlayers" Content="Can Move Players"
                      Foreground="{DynamicResource TextPrimaryBrush}" />
            <CheckBox Name="ChkCanTemporaryBanPlayers" Content="Can Temporarily Ban Players"
                      Foreground="{DynamicResource TextPrimaryBrush}" />
            <CheckBox Name="ChkCanPermanentlyBanPlayers" Content="Can Permanently Ban Players"
                      Foreground="{DynamicResource TextPrimaryBrush}" />
          </StackPanel>
        </Border>

        <!-- Server Lists -->
        <Border Name="PrivGroupLists" IsVisible="False"
                Background="{DynamicResource SurfaceBrush}" CornerRadius="8" Padding="14"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
          <StackPanel Spacing="6">
            <TextBlock Text="SERVER LISTS" FontSize="10" FontWeight="Bold"
                       Foreground="{DynamicResource PrimaryBrush}" Margin="0,0,0,4" />
            <CheckBox Name="ChkCanEditMapList" Content="Can Edit Map List"
                      Foreground="{DynamicResource TextPrimaryBrush}" />
            <CheckBox Name="ChkCanEditBanList" Content="Can Edit Ban List"
                      Foreground="{DynamicResource TextPrimaryBrush}" />
            <CheckBox Name="ChkCanEditReservedSlotsList" Content="Can Edit Reserved Slots List"
                      Foreground="{DynamicResource TextPrimaryBrush}" />
            <CheckBox Name="ChkCanEditTextChatModerationList" Content="Can Edit Text Chat Moderation List"
                      Foreground="{DynamicResource TextPrimaryBrush}" />
            <CheckBox Name="ChkCanEditMapZones" Content="Can Edit Map Zones"
                      Foreground="{DynamicResource TextPrimaryBrush}" />
          </StackPanel>
        </Border>

        <!-- PunkBuster & PRoCon -->
        <Border Name="PrivGroupProcon" IsVisible="False"
                Background="{DynamicResource SurfaceBrush}" CornerRadius="8" Padding="14"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
          <StackPanel Spacing="6">
            <TextBlock Text="PUNKBUSTER &amp; PROCON" FontSize="10" FontWeight="Bold"
                       Foreground="{DynamicResource SecondaryBrush}" Margin="0,0,0,4" />
            <CheckBox Name="ChkCanIssueLimitedPunkbusterCommands" Content="Can Issue Limited PunkBuster Commands"
                      Foreground="{DynamicResource TextPrimaryBrush}" />
            <CheckBox Name="ChkCanIssueAllPunkbusterCommands" Content="Can Issue All PunkBuster Commands"
                      Foreground="{DynamicResource TextPrimaryBrush}" />
            <CheckBox Name="ChkCanIssueLimitedProconCommands" Content="Can Issue Limited PRoCon Commands"
                      Foreground="{DynamicResource TextPrimaryBrush}" />
            <CheckBox Name="ChkCanIssueAllProconCommands" Content="Can Issue All PRoCon Commands"
                      Foreground="{DynamicResource TextPrimaryBrush}" />
            <CheckBox Name="ChkCanIssueLimitedProconPluginCommands" Content="Can Issue Limited Plugin Commands"
                      Foreground="{DynamicResource TextPrimaryBrush}" />
          </StackPanel>
        </Border>

        <!-- Save Button -->
        <Button Name="SavePrivilegesButton" Content="Save Privileges" IsVisible="False"
                Background="{DynamicResource ButtonPrimaryBrush}"
                Foreground="{DynamicResource ButtonPrimaryTextBrush}"
                HorizontalAlignment="Left" Padding="20,10" CornerRadius="6"
                FontSize="13" FontWeight="SemiBold"
                Click="OnSavePrivileges" />

        <TextBlock Name="SaveStatusText" Text="" FontSize="11"
                   Foreground="{DynamicResource TextSecondaryBrush}" />
      </StackPanel>
    </ScrollViewer>
  </Grid>

</UserControl>
