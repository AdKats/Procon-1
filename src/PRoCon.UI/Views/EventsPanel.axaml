<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="PRoCon.UI.Views.EventsPanel"
             x:CompileBindings="False">

  <DockPanel>

    <!-- Top: Filter Options -->
    <Border DockPanel.Dock="Top"
            Background="{DynamicResource SurfaceBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="0,0,0,1"
            Padding="12,8">
      <DockPanel>
        <TextBlock DockPanel.Dock="Left" Text="Event Log" FontSize="16" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"
                   Margin="0,0,16,0" />

        <Button DockPanel.Dock="Right" Content="Clear" Padding="12,6" CornerRadius="4"
                Background="{DynamicResource ButtonSecondaryBrush}"
                Foreground="{DynamicResource ButtonSecondaryTextBrush}"
                Click="OnClearEvents" />

        <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
          <CheckBox Name="FilterConnection" Content="Connection" IsChecked="True"
                    Foreground="{DynamicResource TextPrimaryBrush}" FontSize="12"
                    Click="OnFilterChanged" />
          <CheckBox Name="FilterPlayerlist" Content="Players" IsChecked="True"
                    Foreground="{DynamicResource TextPrimaryBrush}" FontSize="12"
                    Click="OnFilterChanged" />
          <CheckBox Name="FilterBanlist" Content="Bans" IsChecked="True"
                    Foreground="{DynamicResource TextPrimaryBrush}" FontSize="12"
                    Click="OnFilterChanged" />
          <CheckBox Name="FilterMap" Content="Map" IsChecked="True"
                    Foreground="{DynamicResource TextPrimaryBrush}" FontSize="12"
                    Click="OnFilterChanged" />
          <CheckBox Name="FilterPlugins" Content="Plugins" IsChecked="True"
                    Foreground="{DynamicResource TextPrimaryBrush}" FontSize="12"
                    Click="OnFilterChanged" />
          <CheckBox Name="FilterLayer" Content="Layer" IsChecked="True"
                    Foreground="{DynamicResource TextPrimaryBrush}" FontSize="12"
                    Click="OnFilterChanged" />
        </StackPanel>
      </DockPanel>
    </Border>

    <!-- Main: Event List -->
    <Border Background="{DynamicResource BackgroundBrush}" Padding="8">
      <ScrollViewer Name="EventScroller">
        <ItemsControl Name="EventItemsControl">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Border Padding="8,4" Margin="0,1" CornerRadius="4"
                      Background="{DynamicResource SurfaceBrush}">
                <DockPanel>
                  <TextBlock DockPanel.Dock="Left" Text="{Binding Timestamp}"
                             Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"
                             FontFamily="Consolas,Courier New,monospace"
                             VerticalAlignment="Center" Margin="0,0,12,0" Width="140" />
                  <Border DockPanel.Dock="Left" Padding="4,2" CornerRadius="3" Margin="0,0,8,0"
                          Background="{DynamicResource SurfaceElevatedBrush}" VerticalAlignment="Center">
                    <TextBlock Text="{Binding EventTypeName}" FontSize="10" FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryBrush}" />
                  </Border>
                  <TextBlock Text="{Binding EventText}" TextWrapping="Wrap"
                             Foreground="{DynamicResource TextPrimaryBrush}" FontSize="12"
                             VerticalAlignment="Center" />
                </DockPanel>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>
    </Border>

  </DockPanel>

</UserControl>
