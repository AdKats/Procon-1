<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="PRoCon.UI.Views.SettingsDialog"
        x:CompileBindings="False"
        Title="PRoCon Settings"
        Width="600" Height="500"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundBrush}">

  <DockPanel>
    <Border DockPanel.Dock="Bottom" Background="{DynamicResource SurfaceBrush}"
            Padding="16,10" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0">
      <Button Content="Close" HorizontalAlignment="Right"
              Background="{DynamicResource ButtonSecondaryBrush}"
              Foreground="{DynamicResource ButtonSecondaryTextBrush}"
              Padding="20,8" CornerRadius="4"
              Click="OnClose" />
    </Border>
    <ContentControl Name="SettingsContent" />
  </DockPanel>
</Window>
