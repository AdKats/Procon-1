<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="PRoCon.UI.Views.SpectatorListPanel">

  <DockPanel>
    <!-- Header -->
    <TextBlock DockPanel.Dock="Top" Text="Spectator List" FontSize="16" FontWeight="SemiBold"
               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12" />

    <!-- Action buttons -->
    <Border DockPanel.Dock="Top"
            Background="{DynamicResource SurfaceElevatedBrush}"
            CornerRadius="3" Padding="8" Margin="0,0,0,8">
      <StackPanel Orientation="Horizontal" Spacing="6">
        <Button Name="BtnRefresh" Content="Refresh"
                Background="{DynamicResource ButtonSecondaryBrush}"
                Foreground="{DynamicResource ButtonSecondaryTextBrush}"
                Padding="10,6" CornerRadius="4" Click="OnRefresh" />
        <Button Name="BtnRemovePlayer" Content="Remove Selected"
                Background="{DynamicResource ErrorBrush}"
                Foreground="#c8d8e8"
                Padding="10,6" CornerRadius="4" Click="OnRemovePlayer" />
      </StackPanel>
    </Border>

    <!-- Add player form at bottom -->
    <Border DockPanel.Dock="Bottom"
            Background="{DynamicResource SurfaceElevatedBrush}"
            CornerRadius="3" Padding="12" Margin="0,8,0,0">
      <DockPanel>
        <TextBlock DockPanel.Dock="Top" Text="Add Player to Spectator List" FontSize="13" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,8" />
        <Grid ColumnDefinitions="*,Auto">
          <TextBox Grid.Column="0" Name="PlayerNameInput"
                   Watermark="Player name"
                   Background="{DynamicResource InputBackgroundBrush}"
                   Foreground="{DynamicResource TextPrimaryBrush}"
                   BorderBrush="{DynamicResource BorderBrush}"
                   Margin="0,0,8,0" />
          <Button Grid.Column="1" Name="BtnAddPlayer" Content="Add Player"
                  Background="{DynamicResource ButtonPrimaryBrush}"
                  Foreground="{DynamicResource ButtonPrimaryTextBrush}"
                  Padding="14,6" CornerRadius="4"
                  Click="OnAddPlayer" />
        </Grid>
      </DockPanel>
    </Border>

    <!-- Player list -->
    <Border Background="{DynamicResource BackgroundBrush}"
            CornerRadius="3" Padding="4"
            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
      <ListBox Name="SpectatorSlotsList"
               Background="Transparent"
               Foreground="{DynamicResource TextPrimaryBrush}" />
    </Border>
  </DockPanel>

</UserControl>
