<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="PRoCon.UI.Views.MainWindow"
        x:CompileBindings="False"
        Title="PRoCon Frostbite"
        Icon="/procon.ico"
        Width="1200" Height="800"
        MinWidth="900" MinHeight="600"
        Background="{DynamicResource BackgroundBrush}"
        WindowStartupLocation="CenterScreen">

  <Window.Styles>
    <!-- Marquee bounce for long server names -->
    <Style Selector="TextBlock.marquee">
      <Setter Property="Canvas.Left" Value="0" />
      <Style.Animations>
        <Animation Duration="0:0:6" IterationCount="INFINITE" PlaybackDirection="Alternate"
                   Easing="LinearEasing">
          <KeyFrame Cue="0%">
            <Setter Property="Canvas.Left" Value="0" />
          </KeyFrame>
          <KeyFrame Cue="20%">
            <Setter Property="Canvas.Left" Value="0" />
          </KeyFrame>
          <KeyFrame Cue="80%">
            <Setter Property="Canvas.Left" Value="-120" />
          </KeyFrame>
          <KeyFrame Cue="100%">
            <Setter Property="Canvas.Left" Value="-120" />
          </KeyFrame>
        </Animation>
      </Style.Animations>
    </Style>
    <!-- Ripple ring animation -->
    <Style Selector="Ellipse.ripple">
      <Style.Animations>
        <Animation Duration="0:0:2" IterationCount="INFINITE" Easing="CubicEaseOut">
          <KeyFrame Cue="0%">
            <Setter Property="Opacity" Value="0.8" />
            <Setter Property="Width" Value="8" />
            <Setter Property="Height" Value="8" />
          </KeyFrame>
          <KeyFrame Cue="100%">
            <Setter Property="Opacity" Value="0" />
            <Setter Property="Width" Value="20" />
            <Setter Property="Height" Value="20" />
          </KeyFrame>
        </Animation>
      </Style.Animations>
    </Style>
    <!-- Subtle glow pulse -->
    <Style Selector="Ellipse.pulse">
      <Style.Animations>
        <Animation Duration="0:0:2" IterationCount="INFINITE" PlaybackDirection="Alternate"
                   Easing="SineEaseInOut">
          <KeyFrame Cue="0%">
            <Setter Property="Opacity" Value="1.0" />
          </KeyFrame>
          <KeyFrame Cue="100%">
            <Setter Property="Opacity" Value="0.6" />
          </KeyFrame>
        </Animation>
      </Style.Animations>
    </Style>
    <!-- Nav item hover effect -->
    <Style Selector="Button.nav-item:pointerover">
      <Setter Property="Background" Value="{DynamicResource TabHoverBrush}" />
    </Style>
    <!-- Server tab hover -->
    <Style Selector="Button.server-tab:pointerover">
      <Setter Property="Background" Value="{DynamicResource TabHoverBrush}" />
    </Style>
  </Window.Styles>

  <Window.Resources>
    <!-- Shared player list item template (used by all 4 team ListBoxes) -->
    <DataTemplate x:Key="PlayerItemTemplate">
      <Grid ColumnDefinitions="16,22,*,45,35,40,30,35,40" Margin="2,1">
        <Grid.ContextMenu>
          <ContextMenu>
            <MenuItem Header="Kill" Click="OnPlayerKill" />
            <MenuItem Header="Kick..." Click="OnPlayerKick" />
            <Separator />
            <MenuItem Header="Move to Team 1" Click="OnPlayerMoveTeam1" />
            <MenuItem Header="Move to Team 2" Click="OnPlayerMoveTeam2" />
            <MenuItem Header="Move to Team 3" Click="OnPlayerMoveTeam3" />
            <MenuItem Header="Move to Team 4" Click="OnPlayerMoveTeam4" />
            <Separator />
            <MenuItem Header="Ban (Name)..." Click="OnPlayerBan" />
            <Separator />
            <MenuItem Header="Copy Name" Click="OnPlayerCopyName" />
          </ContextMenu>
        </Grid.ContextMenu>
        <TextBlock Grid.Column="0" Text="{Binding StatusIcon}" FontSize="11" VerticalAlignment="Center"
                   Foreground="{DynamicResource ErrorBrush}" HorizontalAlignment="Center" />
        <TextBlock Grid.Column="1" Text="{Binding FlagText}" FontSize="12" VerticalAlignment="Center" />
        <TextBlock Grid.Column="2" Text="{Binding Name}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" Foreground="{DynamicResource TextPrimaryBrush}" />
        <TextBlock Grid.Column="3" Text="{Binding ScoreText}" Foreground="{DynamicResource ScoreBrush}" HorizontalAlignment="Right" />
        <TextBlock Grid.Column="4" Text="{Binding KillsText}" Foreground="{DynamicResource KillsBrush}" HorizontalAlignment="Right" />
        <TextBlock Grid.Column="5" Text="{Binding DeathsText}" Foreground="{DynamicResource DeathsBrush}" HorizontalAlignment="Right" />
        <TextBlock Grid.Column="6" Text="{Binding PingText}" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Right" />
        <TextBlock Grid.Column="7" Text="{Binding SquadText}" Foreground="{DynamicResource TextDisabledBrush}" HorizontalAlignment="Right" />
        <TextBlock Grid.Column="8" Text="{Binding ThreatText}" Foreground="{DynamicResource ErrorBrush}" FontSize="9" FontWeight="Bold" HorizontalAlignment="Right" VerticalAlignment="Center" />
      </Grid>
    </DataTemplate>
  </Window.Resources>

  <DockPanel>

    <!-- ═══════════════════════════════════════════ -->
    <!-- TOP BAR: Logo + Server Tabs + Actions       -->
    <!-- ═══════════════════════════════════════════ -->
    <Border DockPanel.Dock="Top"
            Background="{DynamicResource TopBarBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="0,0,0,1"
            Padding="10,0" Height="44">
      <DockPanel>
        <!-- Logo -->
        <Image DockPanel.Dock="Left"
               Source="/Assets/myrcon_logo.png"
               Height="30"
               VerticalAlignment="Center"
               Margin="0,0,16,0" />

        <!-- Right side: settings -->
        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="6"
                    VerticalAlignment="Center">
          <!-- Hidden status controls (used by code-behind for window title updates) -->
          <Ellipse Name="StatusIndicator" Width="0" Height="0" IsVisible="False"
                   Fill="{DynamicResource DisconnectedBrush}" />
          <TextBlock Name="StatusText" Text="" IsVisible="False" />
          <Button Content="SETTINGS" Classes="secondary"
                  FontSize="11" Padding="8,4" Click="OnOpenSettings" />
          <Button Name="ThemeToggleButton" Content="THEME" Classes="secondary"
                  FontSize="11" Padding="8,4" Click="OnThemeToggle" />
          <Button Content="+" FontSize="14" Padding="8,2"
                  Background="Transparent"
                  Foreground="{DynamicResource TextDisabledBrush}"
                  BorderThickness="0"
                  Click="OnShowConnectForm" />
        </StackPanel>

        <!-- Server tabs (browser-tab style, no scrollbar) -->
        <ListBox Name="ServerList"
                 Background="Transparent" Padding="0"
                 BorderThickness="0"
                 ScrollViewer.HorizontalScrollBarVisibility="Hidden"
                 ScrollViewer.VerticalScrollBarVisibility="Disabled"
                 VerticalAlignment="Bottom" Margin="0,0,0,-1"
                 SelectionChanged="OnServerSelected"
                 DoubleTapped="OnServerDoubleClick">
            <ListBox.ItemsPanel>
              <ItemsPanelTemplate>
                <StackPanel Orientation="Horizontal" Spacing="2" />
              </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
            <ListBox.ItemTemplate>
              <DataTemplate>
                <Border Padding="8,6" CornerRadius="3,3,0,0"
                        BorderBrush="{DynamicResource GlassBorderBrush}"
                        BorderThickness="1,1,1,0"
                        Background="Transparent">
                  <StackPanel Orientation="Horizontal" Spacing="5">
                    <Panel Width="10" Height="10" VerticalAlignment="Center">
                      <Ellipse Width="6" Height="6"
                               Stroke="{Binding StatusColor}" StrokeThickness="1"
                               Fill="Transparent"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Classes.ripple="{Binding IsPulsing}" />
                      <Ellipse Width="6" Height="6"
                               Fill="{Binding StatusColor}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Classes.pulse="{Binding IsPulsing}" />
                    </Panel>
                    <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                            CornerRadius="2" Padding="4,1" VerticalAlignment="Center"
                            IsVisible="{Binding HasGameType}">
                      <TextBlock Text="{Binding GameType}"
                                 Foreground="{DynamicResource PrimaryBrush}"
                                 FontSize="8" FontWeight="SemiBold" />
                    </Border>
                    <TextBlock Name="ServerNameText" Text="{Binding DisplayName}"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               FontSize="10" VerticalAlignment="Center"
                               MaxWidth="140" TextTrimming="CharacterEllipsis" />
                    <TextBlock Text="{Binding PlayerCountText}"
                               Foreground="{DynamicResource TextDisabledBrush}"
                               FontSize="9" VerticalAlignment="Center"
                               IsVisible="{Binding HasPlayerCount}" />
                  </StackPanel>
                </Border>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
      </DockPanel>
    </Border>

    <!-- ═══════════════════════════════════════════ -->
    <!-- BOTTOM STATUS BAR                           -->
    <!-- ═══════════════════════════════════════════ -->
    <Border DockPanel.Dock="Bottom"
            Background="{DynamicResource TopBarBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="0,1,0,0" Padding="14,5">
      <DockPanel>
        <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" Spacing="6"
                    VerticalAlignment="Center">
          <Ellipse Width="5" Height="5" Fill="{DynamicResource ConnectedBrush}"
                   Classes="pulse-dot" />
          <TextBlock Name="ConnectionCountText" Text="0 connections"
                     Foreground="{DynamicResource TextSecondaryBrush}" FontSize="9" />
        </StackPanel>
        <TextBlock DockPanel.Dock="Right"
                   Foreground="{DynamicResource TextDisabledBrush}" FontSize="9"
                   HorizontalAlignment="Right" VerticalAlignment="Center">
          <Run Text="PRoCon" /><Run Text=" " />
          <Run Text="v2.0.0" Foreground="{DynamicResource TextSecondaryBrush}" />
        </TextBlock>
      </DockPanel>
    </Border>

    <!-- ═══════════════════════════════════════════ -->
    <!-- MAIN BODY: Vertical Nav + Content           -->
    <!-- ═══════════════════════════════════════════ -->
    <DockPanel>

      <!-- Update Banner -->
      <Border DockPanel.Dock="Top" Name="UpdateBanner" IsVisible="False"
              Background="{DynamicResource ButtonPrimaryGradient}"
              BorderBrush="{DynamicResource GlassBorderBrush}"
              BorderThickness="0,0,0,1" Padding="12,6">
        <DockPanel>
          <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
            <ProgressBar Name="UpdateProgressBar" IsVisible="False" Width="120" Height="4"
                         Minimum="0" Maximum="100" Value="0" VerticalAlignment="Center"
                         Foreground="{DynamicResource PrimaryBrush}" />
            <Button Name="UpdateInstallButton" Content="INSTALL" IsVisible="False"
                    Click="OnUpdateInstall" Padding="10,4" FontSize="9" />
            <Button Name="UpdateLaterButton" Content="LATER" IsVisible="False"
                    Click="OnUpdateLater" Padding="10,4" FontSize="9"                     Classes="secondary" />
          </StackPanel>
          <TextBlock Name="UpdateBannerText" Text=""
                     Foreground="{DynamicResource PrimaryBrush}" FontSize="10"
                     VerticalAlignment="Center" />
        </DockPanel>
      </Border>

      <!-- Left Vertical Navigation -->
      <Border DockPanel.Dock="Left" Width="150"
              Background="{DynamicResource SurfaceBrush}"
              BorderBrush="{DynamicResource BorderBrush}"
              BorderThickness="0,0,1,0"
              Name="TabBarBorder" IsVisible="False">
        <DockPanel>
          <!-- Server action buttons at bottom -->
          <StackPanel DockPanel.Dock="Bottom" Margin="6,4" Spacing="3">
            <Button Name="ConnectSelectedButton"
                    Content="CONNECT"
                    Foreground="{DynamicResource SuccessBrush}"
                    Background="{DynamicResource ToggleOnBrush}"
                    BorderBrush="{DynamicResource ToggleOnBorderBrush}"
                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                    Padding="6,4" FontSize="11"                     IsVisible="False"
                    Click="OnConnectSelected" />
            <Button Name="DisconnectButton"
                    Content="DISCONNECT" Classes="danger"
                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                    Padding="6,4" FontSize="11"                     IsVisible="False"
                    Click="OnDisconnect" />
            <Button Name="RemoveServerButton"
                    Content="REMOVE" Classes="danger"
                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                    Padding="6,4" FontSize="11"                     IsVisible="False"
                    Click="OnRemoveServer" />
          </StackPanel>

          <!-- Options at bottom with separator -->
          <Border DockPanel.Dock="Bottom"
                  BorderBrush="{DynamicResource SeparatorBrush}"
                  BorderThickness="0,1,0,0" Margin="0,4,0,0">
            <Button Content="DASHBOARD" Tag="0" Padding="12,8"
                    Background="Transparent" FontSize="11"
                    Foreground="{DynamicResource TextDisabledBrush}"
                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
 Classes="nav-item"
                    Click="OnGoHome" />
          </Border>

          <!-- Feature tab buttons (vertical) -->
          <ScrollViewer VerticalScrollBarVisibility="Auto"
                        HorizontalScrollBarVisibility="Disabled">
            <StackPanel Name="TabBar" Spacing="0" Margin="0,4">
              <Button Content="INFO" Tag="6" Padding="12,8"
                      Background="Transparent" FontSize="11"
                      Foreground="{DynamicResource PrimaryBrush}" FontWeight="SemiBold"
                      HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
 BorderThickness="2,0,0,0"
                      BorderBrush="{DynamicResource PrimaryBrush}"
                      Classes="nav-item"
                      Click="OnTabClick" />
              <Button Content="CHAT" Tag="1" Padding="12,8"
                      Background="Transparent" FontSize="11"
                      Foreground="{DynamicResource TextDisabledBrush}"
                      HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
 BorderThickness="2,0,0,0" BorderBrush="Transparent"
                      Classes="nav-item"
                      Click="OnTabClick" />
              <Button Content="PLAYERS" Tag="2" Padding="12,8"
                      Background="Transparent" FontSize="11"
                      Foreground="{DynamicResource TextDisabledBrush}"
                      HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
 BorderThickness="2,0,0,0" BorderBrush="Transparent"
                      Classes="nav-item"
                      Click="OnTabClick" />
              <Button Content="MAPS" Tag="3" Padding="12,8"
                      Background="Transparent" FontSize="11"
                      Foreground="{DynamicResource TextDisabledBrush}"
                      HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
 BorderThickness="2,0,0,0" BorderBrush="Transparent"
                      Classes="nav-item"
                      Click="OnTabClick" />
              <Button Content="BANS" Tag="4" Padding="12,8"
                      Background="Transparent" FontSize="11"
                      Foreground="{DynamicResource TextDisabledBrush}"
                      HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
 BorderThickness="2,0,0,0" BorderBrush="Transparent"
                      Classes="nav-item"
                      Click="OnTabClick" />
              <Button Content="RESERVED" Tag="5" Padding="12,8"
                      Background="Transparent" FontSize="11"
                      Foreground="{DynamicResource TextDisabledBrush}"
                      HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
 BorderThickness="2,0,0,0" BorderBrush="Transparent"
                      Classes="nav-item"
                      Click="OnTabClick" />
              <Button Content="SPECTATORS" Tag="14" Padding="12,8"
                      Background="Transparent" FontSize="11"
                      Foreground="{DynamicResource TextDisabledBrush}"
                      HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
 BorderThickness="2,0,0,0" BorderBrush="Transparent"
                      Classes="nav-item"
                      Click="OnTabClick" />
              <Button Content="PUNKBUSTER" Tag="15" Padding="12,8"
                      Background="Transparent" FontSize="11"
                      Foreground="{DynamicResource TextDisabledBrush}"
                      HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
 BorderThickness="2,0,0,0" BorderBrush="Transparent"
                      Classes="nav-item"
                      Click="OnTabClick" />
              <Button Content="CHAT MOD" Tag="16" Padding="12,8"
                      Background="Transparent" FontSize="11"
                      Foreground="{DynamicResource TextDisabledBrush}"
                      HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
 BorderThickness="2,0,0,0" BorderBrush="Transparent"
                      Classes="nav-item"
                      Click="OnTabClick" />
              <Button Content="SETTINGS" Tag="7" Padding="12,8"
                      Background="Transparent" FontSize="11"
                      Foreground="{DynamicResource TextDisabledBrush}"
                      HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
 BorderThickness="2,0,0,0" BorderBrush="Transparent"
                      Classes="nav-item"
                      Click="OnTabClick" />
              <Button Content="PLUGINS" Tag="8" Padding="12,8"
                      Background="Transparent" FontSize="11"
                      Foreground="{DynamicResource TextDisabledBrush}"
                      HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
 BorderThickness="2,0,0,0" BorderBrush="Transparent"
                      Classes="nav-item"
                      Click="OnTabClick" />
              <Button Content="ACCOUNTS" Tag="9" Padding="12,8"
                      Background="Transparent" FontSize="11"
                      Foreground="{DynamicResource TextDisabledBrush}"
                      HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
 BorderThickness="2,0,0,0" BorderBrush="Transparent"
                      Classes="nav-item"
                      Click="OnTabClick" />
              <Button Content="EVENTS" Tag="10" Padding="12,8"
                      Background="Transparent" FontSize="11"
                      Foreground="{DynamicResource TextDisabledBrush}"
                      HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
 BorderThickness="2,0,0,0" BorderBrush="Transparent"
                      Classes="nav-item"
                      Click="OnTabClick" />
              <Button Content="CONSOLE" Tag="11" Padding="12,8"
                      Background="Transparent" FontSize="11"
                      Foreground="{DynamicResource TextDisabledBrush}"
                      HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
 BorderThickness="2,0,0,0" BorderBrush="Transparent"
                      Classes="nav-item"
                      Click="OnTabClick" />
              <Button Name="LayerTabButton" Content="LAYER" Tag="12" Padding="12,8"
                      Background="Transparent" FontSize="11"
                      Foreground="{DynamicResource TextDisabledBrush}"
                      HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
 BorderThickness="2,0,0,0" BorderBrush="Transparent"
                      Classes="nav-item"
                      Click="OnTabClick" />
            </StackPanel>
          </ScrollViewer>
        </DockPanel>
      </Border>

      <!-- ═══════════════════════════════════════════ -->
      <!-- BREADCRUMB CONTEXT BAR                      -->
      <!-- ═══════════════════════════════════════════ -->
      <Border DockPanel.Dock="Top" Name="BreadcrumbBar" IsVisible="False"
              BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"
              Padding="14,6"
              Background="{DynamicResource GlassHeaderBrush}">
        <DockPanel>
          <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" Spacing="6"
                      VerticalAlignment="Center">
            <TextBlock Name="BreadcrumbServerName" Text=""
                       Foreground="{DynamicResource TextDisabledBrush}" FontSize="9" />
            <TextBlock Text="//" Foreground="{DynamicResource SeparatorBrush}" FontSize="9" />
            <TextBlock Name="BreadcrumbTabName" Text="INFO"
                       Foreground="{DynamicResource BreadcrumbActiveTextBrush}" FontSize="9" />
          </StackPanel>
          <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="14"
                      VerticalAlignment="Center">
            <TextBlock Name="BreadcrumbPlayers" Text=""
                       Foreground="{DynamicResource TextDisabledBrush}" FontSize="9" />
            <TextBlock Name="BreadcrumbTickets" Text=""
                       Foreground="{DynamicResource TextDisabledBrush}" FontSize="9" />
            <TextBlock Name="BreadcrumbPing" Text=""
                       Foreground="{DynamicResource TextDisabledBrush}" FontSize="9" />
          </StackPanel>
        </DockPanel>
      </Border>

      <!-- ═══════════════════════════════════════════ -->
      <!-- CONTENT AREA with grid overlay              -->
      <!-- ═══════════════════════════════════════════ -->
      <Panel>
        <!-- Grid overlay background (40px lines, drift animation) -->
        <Canvas Name="GridOverlay" ClipToBounds="True" IsHitTestVisible="False"
                Opacity="0.4" />
        <Border Padding="12">
          <Panel>

          <!-- ═══════════════════════════════════════ -->
          <!-- Landing / Disconnected Overlay          -->
          <!-- ═══════════════════════════════════════ -->
          <Border Name="DisconnectedOverlay" IsVisible="True"
                  Classes="glass-panel">
            <ScrollViewer>
              <StackPanel Spacing="0" Margin="40,40"
                          HorizontalAlignment="Center" VerticalAlignment="Center">
                <!-- Branding -->
                <TextBlock Text="PRoCon" FontSize="32" FontWeight="Bold"
                           Foreground="{DynamicResource PrimaryBrush}"
                           HorizontalAlignment="Center"
 />
                <TextBlock Text="FROSTBITE RCON ADMINISTRATION" FontSize="10"
                           Foreground="{DynamicResource TextDisabledBrush}"
                           HorizontalAlignment="Center"
 Margin="0,6,0,0" />

                <!-- Status ring -->
                <Border Width="60" Height="60" CornerRadius="30"
                        Background="Transparent"
                        BorderBrush="{DynamicResource GlassBorderBrush}" BorderThickness="2"
                        HorizontalAlignment="Center" Margin="0,30,0,0">
                  <Panel>
                    <Ellipse Width="60" Height="60" StrokeThickness="2"
                             Stroke="{DynamicResource GlassBorderBrush}" Fill="Transparent"
                             HorizontalAlignment="Center" VerticalAlignment="Center"
                             Classes="ripple-ring" />
                    <TextBlock Name="OverlayIcon" Text="+" FontSize="24" FontWeight="Light"
                               Foreground="{DynamicResource TextDisabledBrush}"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                  </Panel>
                </Border>

                <!-- Add Server CTA -->
                <Button Content="+ ADD SERVER"
                        Padding="24,10" FontSize="10"
                        HorizontalAlignment="Center" Margin="0,24,0,0"
                        Click="OnShowConnectForm" />

                <TextBlock Name="OverlayTitle" Text="" IsVisible="False" />
                <TextBlock Name="DisconnectedSubtext" Text="" IsVisible="False" />

                <!-- Stats row -->
                <StackPanel Orientation="Horizontal" Spacing="24"
                            HorizontalAlignment="Center" Margin="0,32,0,0">
                  <StackPanel HorizontalAlignment="Center">
                    <TextBlock Name="LandingServerCount" Text="0" FontSize="22" FontWeight="Bold"
                               Foreground="{DynamicResource PrimaryBrush}"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="SERVERS" FontSize="11"
                               Foreground="{DynamicResource TextDisabledBrush}"
                               HorizontalAlignment="Center" />
                  </StackPanel>
                  <Border Width="1" Height="32" Background="{DynamicResource SeparatorBrush}" />
                  <StackPanel HorizontalAlignment="Center">
                    <TextBlock Name="LandingConnectedCount" Text="0" FontSize="22" FontWeight="Bold"
                               Foreground="{DynamicResource SuccessBrush}"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="ONLINE" FontSize="11"
                               Foreground="{DynamicResource TextDisabledBrush}"
                               HorizontalAlignment="Center" />
                  </StackPanel>
                  <Border Width="1" Height="32" Background="{DynamicResource SeparatorBrush}" />
                  <StackPanel HorizontalAlignment="Center">
                    <TextBlock Name="LandingTotalPlayers" Text="0" FontSize="22" FontWeight="Bold"
                               Foreground="{DynamicResource SecondaryBrush}"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="PLAYERS" FontSize="11"
                               Foreground="{DynamicResource TextDisabledBrush}"
                               HorizontalAlignment="Center" />
                  </StackPanel>
                </StackPanel>

                <!-- Supported games -->
                <StackPanel Orientation="Horizontal" Spacing="8"
                            HorizontalAlignment="Center" Margin="0,24,0,0">
                  <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                          CornerRadius="2" Padding="8,4">
                    <TextBlock Text="BF4" FontSize="11" Foreground="{DynamicResource TextDisabledBrush}"
 />
                  </Border>
                  <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                          CornerRadius="2" Padding="8,4">
                    <TextBlock Text="BF3" FontSize="11" Foreground="{DynamicResource TextDisabledBrush}"
 />
                  </Border>
                  <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                          CornerRadius="2" Padding="8,4">
                    <TextBlock Text="BFH" FontSize="11" Foreground="{DynamicResource TextDisabledBrush}"
 />
                  </Border>
                  <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                          CornerRadius="2" Padding="8,4">
                    <TextBlock Text="MOH" FontSize="11" Foreground="{DynamicResource TextDisabledBrush}"
 />
                  </Border>
                </StackPanel>

                <!-- Server Overview Cards (populated by code-behind) -->
                <Border Margin="0,32,0,0" IsVisible="False" Name="DashboardCardsSection">
                  <StackPanel Spacing="8">
                    <TextBlock Text="SERVER OVERVIEW" FontSize="10"
                               Foreground="{DynamicResource TextDisabledBrush}"
                               HorizontalAlignment="Center" Classes="section-label" />
                    <ItemsControl Name="DashboardServerCards">
                      <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                          <WrapPanel Orientation="Horizontal" HorizontalAlignment="Center" />
                        </ItemsPanelTemplate>
                      </ItemsControl.ItemsPanel>
                    </ItemsControl>
                  </StackPanel>
                </Border>

              </StackPanel>
            </ScrollViewer>
          </Border>

          <!-- ═══════════════════════════════════════ -->
          <!-- Tab 1: Chat                             -->
          <!-- ═══════════════════════════════════════ -->
          <Border Name="Tab1" IsVisible="False" Classes="glass-panel">
            <DockPanel>
              <!-- Header -->
              <Border DockPanel.Dock="Top" Classes="glass-header">
                <TextBlock Text="CHAT LOG" Classes="section-label" />
              </Border>
              <!-- Input bar -->
              <Border DockPanel.Dock="Bottom"
                      BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0"
                      Padding="12,8">
                <DockPanel>
                  <TextBlock DockPanel.Dock="Left" Text="SAY"
                             Foreground="{DynamicResource TextDisabledBrush}" FontSize="9"
                             VerticalAlignment="Center" Margin="0,0,8,0"
 />
                  <Button DockPanel.Dock="Right" Content="SEND" Margin="8,0,0,0"
                          Padding="12,6" FontSize="9"                           Click="OnSendChat" />
                  <TextBox Name="ChatInput" Watermark="Type a message..."
                           KeyDown="OnChatInputKeyDown" />
                </DockPanel>
              </Border>
              <!-- Chat log -->
              <ScrollViewer Name="ChatScroller" Padding="12,8">
                <TextBlock Name="ChatLog" TextWrapping="Wrap"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           FontSize="11" />
              </ScrollViewer>
            </DockPanel>
          </Border>

          <!-- ═══════════════════════════════════════ -->
          <!-- Tab 2: Players                          -->
          <!-- ═══════════════════════════════════════ -->
          <Border Name="Tab2" IsVisible="False" Classes="glass-panel">
            <DockPanel>
              <Border DockPanel.Dock="Top" Classes="glass-header">
                <TextBlock Text="PLAYER LIST" Classes="section-label" />
              </Border>
              <!-- Player Actions side panel -->
              <Border DockPanel.Dock="Right" Width="240" Margin="0,8,8,8">
                <ContentControl Name="PlayerActionsContent" />
              </Border>
              <DockPanel Margin="8">
                <!-- Spectators & Commanders bar (below teams) -->
                <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="4,0,4,4">
                  <!-- Commanders -->
                  <Border Name="CommanderPanel" CornerRadius="3" Margin="0,0,4,0" IsVisible="False"
                          Background="{DynamicResource SurfaceBrush}"
                          BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                          MinWidth="200">
                    <DockPanel>
                      <Border DockPanel.Dock="Top" Background="{DynamicResource GlassHeaderBrush}"
                              Padding="8,5" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                        <TextBlock Name="CommanderHeader" Text="Commanders (0)"
                                   FontWeight="SemiBold" FontSize="9"
                                   Foreground="{DynamicResource WarningBrush}" />
                      </Border>
                      <ListBox Name="CommanderList" Background="Transparent"
                               Foreground="{DynamicResource TextPrimaryBrush}" FontSize="10"
                               SelectionMode="Multiple"
                               Padding="2" ItemTemplate="{StaticResource PlayerItemTemplate}" />
                    </DockPanel>
                  </Border>
                  <!-- Spectators -->
                  <Border Name="SpectatorPanel" CornerRadius="3" IsVisible="False"
                          Background="{DynamicResource SurfaceBrush}"
                          BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                          MinWidth="200">
                    <DockPanel>
                      <Border DockPanel.Dock="Top" Background="{DynamicResource GlassHeaderBrush}"
                              Padding="8,5" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                        <TextBlock Name="SpectatorHeader" Text="Spectators (0)"
                                   FontWeight="SemiBold" FontSize="9"
                                   Foreground="{DynamicResource TextDisabledBrush}" />
                      </Border>
                      <ListBox Name="SpectatorList" Background="Transparent"
                               Foreground="{DynamicResource TextPrimaryBrush}" FontSize="10"
                               SelectionMode="Multiple"
                               Padding="2" ItemTemplate="{StaticResource PlayerItemTemplate}" />
                    </DockPanel>
                  </Border>
                </StackPanel>

                <!-- Team grid -->
                <Grid ColumnDefinitions="*,*" RowDefinitions="*,Auto" Name="TeamGrid">
                  <!-- Team 1 -->
                  <Border Grid.Row="0" Grid.Column="0" Margin="4" CornerRadius="3"
                          Background="{DynamicResource SurfaceBrush}"
                          BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                          Name="TeamPanel1">
                    <DockPanel>
                      <Border DockPanel.Dock="Top" Background="{DynamicResource GlassHeaderBrush}"
                              Padding="8,5" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                        <TextBlock Name="TeamHeader1" Text="Team 1 (0)"
                                   FontWeight="SemiBold" FontSize="9"
                                   Foreground="{DynamicResource PrimaryBrush}" />
                      </Border>
                      <ListBox Name="TeamList1" Background="Transparent"
                               Foreground="{DynamicResource TextPrimaryBrush}" FontSize="10"
                               SelectionMode="Multiple"
                               Padding="2" ItemTemplate="{StaticResource PlayerItemTemplate}">
                      </ListBox>
                    </DockPanel>
                  </Border>
                  <!-- Team 2 -->
                  <Border Grid.Row="0" Grid.Column="1" Margin="4" CornerRadius="3"
                          Background="{DynamicResource SurfaceBrush}"
                          BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                          Name="TeamPanel2">
                    <DockPanel>
                      <Border DockPanel.Dock="Top" Background="{DynamicResource GlassHeaderBrush}"
                              Padding="8,5" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                        <TextBlock Name="TeamHeader2" Text="Team 2 (0)"
                                   FontWeight="SemiBold" FontSize="9"
                                   Foreground="{DynamicResource PrimaryBrush}" />
                      </Border>
                      <ListBox Name="TeamList2" Background="Transparent"
                               Foreground="{DynamicResource TextPrimaryBrush}" FontSize="10"
                               SelectionMode="Multiple"
                               Padding="2" ItemTemplate="{StaticResource PlayerItemTemplate}">
                      </ListBox>
                    </DockPanel>
                  </Border>
                  <!-- Team 3 -->
                  <Border Grid.Row="1" Grid.Column="0" Margin="4" CornerRadius="3"
                          Background="{DynamicResource SurfaceBrush}"
                          BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                          Name="TeamPanel3" IsVisible="False">
                    <DockPanel>
                      <Border DockPanel.Dock="Top" Background="{DynamicResource GlassHeaderBrush}"
                              Padding="8,5" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                        <TextBlock Name="TeamHeader3" Text="Team 3 (0)"
                                   FontWeight="SemiBold" FontSize="9"
                                   Foreground="{DynamicResource PrimaryBrush}" />
                      </Border>
                      <ListBox Name="TeamList3" Background="Transparent"
                               Foreground="{DynamicResource TextPrimaryBrush}" FontSize="10"
                               SelectionMode="Multiple"
                               Padding="2" ItemTemplate="{StaticResource PlayerItemTemplate}">
                      </ListBox>
                    </DockPanel>
                  </Border>
                  <!-- Team 4 -->
                  <Border Grid.Row="1" Grid.Column="1" Margin="4" CornerRadius="3"
                          Background="{DynamicResource SurfaceBrush}"
                          BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                          Name="TeamPanel4" IsVisible="False">
                    <DockPanel>
                      <Border DockPanel.Dock="Top" Background="{DynamicResource GlassHeaderBrush}"
                              Padding="8,5" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                        <TextBlock Name="TeamHeader4" Text="Team 4 (0)"
                                   FontWeight="SemiBold" FontSize="9"
                                   Foreground="{DynamicResource PrimaryBrush}" />
                      </Border>
                      <ListBox Name="TeamList4" Background="Transparent"
                               Foreground="{DynamicResource TextPrimaryBrush}" FontSize="10"
                               SelectionMode="Multiple"
                               Padding="2" ItemTemplate="{StaticResource PlayerItemTemplate}">
                      </ListBox>
                    </DockPanel>
                  </Border>
                </Grid>
              </DockPanel>
            </DockPanel>
          </Border>

          <!-- ═══════════════════════════════════════ -->
          <!-- Tab 3: Maps                             -->
          <!-- ═══════════════════════════════════════ -->
          <Border Name="Tab3" IsVisible="False" Classes="glass-panel" Padding="0">
            <ContentControl Name="MapListContent" />
          </Border>

          <!-- Tab 4: Bans -->
          <Border Name="Tab4" IsVisible="False" Classes="glass-panel" Padding="0">
            <ContentControl Name="BanListContent" />
          </Border>

          <!-- Tab 5: Reserved Slots -->
          <Border Name="Tab5" IsVisible="False" Classes="glass-panel" Padding="0">
            <ContentControl Name="ReservedSlotsContent" />
          </Border>

          <!-- ═══════════════════════════════════════ -->
          <!-- Tab 6: Server Info — Command Center     -->
          <!-- ═══════════════════════════════════════ -->
          <Border Name="Tab6" IsVisible="False" Classes="glass-panel">
            <DockPanel>
              <!-- Command Center Header -->
              <Border DockPanel.Dock="Top" Classes="glass-header">
                <DockPanel>
                  <StackPanel>
                    <TextBlock Name="DashServerName" Text="Server Name"
                               FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" />
                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                      <TextBlock Name="DashGameType" Text="BF4" FontSize="9"
                                 Foreground="{DynamicResource PrimaryBrush}" />
                      <TextBlock Text="//" Foreground="{DynamicResource TextDisabledBrush}" FontSize="9" />
                      <TextBlock Name="DashMapMode" Text="Map — Game Mode"
                                 FontSize="9" Foreground="{DynamicResource TextSecondaryBrush}" />
                    </StackPanel>
                  </StackPanel>
                  <!-- Live stats on right -->
                  <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="16"
                              VerticalAlignment="Center">
                    <StackPanel HorizontalAlignment="Center">
                      <TextBlock Name="DashPlayerCount" Text="0/0"
                                 FontSize="18" FontWeight="Bold"
                                 Foreground="{DynamicResource PrimaryBrush}"
                                 HorizontalAlignment="Center" />
                      <TextBlock Text="PLR" FontSize="7"
                                 Foreground="{DynamicResource TextDisabledBrush}"
                                 HorizontalAlignment="Center" />
                    </StackPanel>
                    <Border Width="1" Height="28" Background="{DynamicResource SeparatorBrush}" />
                    <StackPanel HorizontalAlignment="Center">
                      <TextBlock Name="DashTeam1Score" Text="0"
                                 FontSize="18" FontWeight="Bold"
                                 Foreground="{DynamicResource SecondaryBrush}"
                                 HorizontalAlignment="Center" />
                      <TextBlock Text="T1" FontSize="7"
                                 Foreground="{DynamicResource TextDisabledBrush}"
                                 HorizontalAlignment="Center" />
                    </StackPanel>
                    <TextBlock Text="vs" Foreground="{DynamicResource TextDisabledBrush}"
                               FontSize="9" VerticalAlignment="Center" />
                    <StackPanel HorizontalAlignment="Center">
                      <TextBlock Name="DashTeam2Score" Text="0"
                                 FontSize="18" FontWeight="Bold"
                                 Foreground="{DynamicResource SecondaryBrush}"
                                 HorizontalAlignment="Center" />
                      <TextBlock Text="T2" FontSize="7"
                                 Foreground="{DynamicResource TextDisabledBrush}"
                                 HorizontalAlignment="Center" />
                    </StackPanel>
                  </StackPanel>
                </DockPanel>
              </Border>

              <!-- Body content -->
              <ScrollViewer Padding="12">
                <StackPanel Spacing="10">
                  <!-- Badges row -->
                  <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Name="DashServerVersion" Text="R55" FontSize="9"
                               Foreground="{DynamicResource SecondaryBrush}" />
                    <Border Name="DashRankedBadge" BorderBrush="{DynamicResource ToggleOnBorderBrush}"
                            BorderThickness="1" CornerRadius="2" Padding="6,2"
                            Background="{DynamicResource ToggleOnBrush}">
                      <TextBlock Name="DashRankedText" Text="RANKED" FontSize="11"
                                 Foreground="{DynamicResource SuccessBrush}" />
                    </Border>
                    <Border Name="DashPbBadge" BorderBrush="#4Dab47bc" BorderThickness="1"
                            CornerRadius="2" Padding="6,2" IsVisible="False"
                            Background="#1Aab47bc">
                      <TextBlock Text="PUNKBUSTER" FontSize="11"
                                 Foreground="#ab47bc" />
                    </Border>
                  </StackPanel>

                  <!-- Stats grid -->
                  <Grid ColumnDefinitions="*,*,*,*" Name="StatsCardsGrid">
                    <Border Grid.Column="0" Background="{DynamicResource SurfaceBrush}"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                            CornerRadius="3" Padding="12,8" Margin="0,0,4,0">
                      <StackPanel>
                        <TextBlock Text="ROUND" FontSize="11" Foreground="{DynamicResource TextDisabledBrush}" LetterSpacing="2" />
                        <TextBlock Name="DashRound" Text="1 / 1" FontSize="16" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,2,0,0" />
                      </StackPanel>
                    </Border>
                    <Border Grid.Column="1" Background="{DynamicResource SurfaceBrush}"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                            CornerRadius="3" Padding="12,8" Margin="2,0">
                      <StackPanel>
                        <TextBlock Text="UPTIME" FontSize="11" Foreground="{DynamicResource TextDisabledBrush}" LetterSpacing="2" />
                        <TextBlock Name="DashUptime" Text="--" FontSize="16" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,2,0,0" />
                      </StackPanel>
                    </Border>
                    <Border Grid.Column="2" Background="{DynamicResource SurfaceBrush}"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                            CornerRadius="3" Padding="12,8" Margin="2,0">
                      <StackPanel>
                        <TextBlock Text="ROUND TIME" FontSize="11" Foreground="{DynamicResource TextDisabledBrush}" LetterSpacing="2" />
                        <TextBlock Name="DashRoundTime" Text="--" FontSize="16" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,2,0,0" />
                      </StackPanel>
                    </Border>
                    <Border Grid.Column="3" Background="{DynamicResource SurfaceBrush}"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                            CornerRadius="3" Padding="12,8" Margin="4,0,0,0">
                      <StackPanel>
                        <TextBlock Text="REGION" FontSize="11" Foreground="{DynamicResource TextDisabledBrush}" LetterSpacing="2" />
                        <TextBlock Name="DashRegion" Text="--" FontSize="16" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,2,0,0" />
                      </StackPanel>
                    </Border>
                  </Grid>

                  <!-- Team scores (hidden, used in header now) -->
                  <Grid Name="TeamScoresGrid" IsVisible="False" />

                  <!-- Player graph + Kill feed -->
                  <Grid ColumnDefinitions="*,*">
                    <Border Grid.Column="0" Background="{DynamicResource SurfaceBrush}"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                            CornerRadius="3" Padding="12,8" Margin="0,0,4,0">
                      <StackPanel Spacing="6">
                        <TextBlock Text="PLAYER COUNT" FontSize="11"
                                   Foreground="{DynamicResource TextDisabledBrush}" />
                        <Canvas Name="PlayerGraphCanvas" Height="100" Background="Transparent"
                                ClipToBounds="True" />
                        <TextBlock Name="DashGraphRange" Text="Last 30 minutes"
                                   FontSize="9" Foreground="{DynamicResource TextDisabledBrush}"
                                   HorizontalAlignment="Center" />
                      </StackPanel>
                    </Border>
                    <Border Grid.Column="1" Background="{DynamicResource SurfaceBrush}"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                            CornerRadius="3" Padding="12,8" Margin="4,0,0,0">
                      <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="KILL FEED" FontSize="11"
                                   Foreground="{DynamicResource TextDisabledBrush}"
 Margin="0,0,0,6" />
                        <ListBox Name="KillFeedList" Background="Transparent" MaxHeight="120"
                                 Foreground="{DynamicResource TextPrimaryBrush}" FontSize="10"
                                 Padding="0" BorderThickness="0" />
                      </DockPanel>
                    </Border>
                  </Grid>

                  <!-- Connection details -->
                  <Border Background="{DynamicResource SurfaceBrush}"
                          BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                          CornerRadius="3" Padding="12,8">
                    <StackPanel Spacing="4">
                      <TextBlock Text="CONNECTION DETAILS" FontSize="11"
                                 Foreground="{DynamicResource TextDisabledBrush}"
 Margin="0,0,0,4" />
                      <TextBlock Name="DashConnectionInfo" TextWrapping="Wrap"
                                 Foreground="{DynamicResource TextSecondaryBrush}" FontSize="10" />
                    </StackPanel>
                  </Border>

                  <TextBlock Name="ServerInfoDetails" IsVisible="False" />
                </StackPanel>
              </ScrollViewer>
            </DockPanel>
          </Border>

          <!-- Tab 7: Server Settings -->
          <Border Name="Tab7" IsVisible="False" Classes="glass-panel" Padding="0">
            <ContentControl Name="ServerSettingsContent" />
          </Border>

          <!-- Tab 8: Plugins -->
          <Border Name="Tab8" IsVisible="False" Classes="glass-panel" Padding="0">
            <ContentControl Name="PluginsContent" />
          </Border>

          <!-- Tab 9: Accounts -->
          <Border Name="Tab9" IsVisible="False" Classes="glass-panel" Padding="0">
            <ContentControl Name="AccountsContent" />
          </Border>

          <!-- Tab 10: Events -->
          <Border Name="Tab10" IsVisible="False" Classes="glass-panel" Padding="0">
            <ContentControl Name="EventsContent" />
          </Border>

          <!-- ═══════════════════════════════════════ -->
          <!-- Tab 11: RCON Console                    -->
          <!-- ═══════════════════════════════════════ -->
          <Border Name="Tab11" IsVisible="False" Classes="glass-panel">
            <DockPanel>
              <Border DockPanel.Dock="Top" Classes="glass-header">
                <DockPanel>
                  <TextBlock Text="RCON CONSOLE" Classes="section-label" />
                  <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="4">
                    <Button Content="COPY" Click="OnCopyConsoleSelected"
                            Padding="6,3" FontSize="11" Classes="secondary" />
                    <Button Content="COPY ALL" Click="OnCopyConsoleAll"
                            Padding="6,3" FontSize="11" Classes="secondary" />
                    <Button Content="CLEAR" Click="OnClearConsole"
                            Padding="6,3" FontSize="11" Classes="secondary" />
                  </StackPanel>
                </DockPanel>
              </Border>
              <!-- Input bar -->
              <StackPanel DockPanel.Dock="Bottom" Margin="0">
                <ListBox Name="ConsoleSuggestions" IsVisible="False" MaxHeight="160"
                         Background="{DynamicResource SurfaceBrush}"
                         Foreground="{DynamicResource TextPrimaryBrush}"
                         BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                         CornerRadius="2" Margin="8,0,8,2" Padding="2"
                         FontSize="10"
                         DoubleTapped="OnSuggestionSelected" />
                <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0"
                        Padding="12,8">
                  <DockPanel>
                    <TextBlock DockPanel.Dock="Left" Text="❯"
                               Foreground="{DynamicResource PrimaryBrush}" FontSize="11"
                               VerticalAlignment="Center" Margin="0,0,8,0" />
                    <Button DockPanel.Dock="Right" Content="SEND" Margin="8,0,0,0"
                            Padding="12,6" FontSize="9"                             Click="OnSendConsoleCommand" />
                    <TextBox Name="ConsoleInput" Watermark="Enter RCON command..."
                             KeyDown="OnConsoleInputKeyDown"
                             TextChanged="OnConsoleInputTextChanged" />
                  </DockPanel>
                </Border>
              </StackPanel>
              <!-- Console log -->
              <ListBox Name="ConsoleLogList" Background="{DynamicResource ConsoleBackgroundBrush}"
                       SelectionMode="Multiple"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       FontSize="10" Margin="8" Padding="4">
                <ListBox.ItemTemplate>
                  <DataTemplate>
                    <TextBlock Text="{Binding Text}" Foreground="{Binding ColorBrush}"
                               FontWeight="{Binding Weight}"
                               TextWrapping="Wrap" />
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>
            </DockPanel>
          </Border>

          <!-- Tab 12: Layer -->
          <Border Name="Tab12" IsVisible="False" Classes="glass-panel" Padding="0">
            <ContentControl Name="LayerContent" />
          </Border>

          <!-- Tab 14: Spectator List -->
          <Border Name="Tab14" IsVisible="False" Classes="glass-panel" Padding="0">
            <ContentControl Name="SpectatorContent" />
          </Border>

          <!-- Tab 15: PunkBuster -->
          <Border Name="Tab15" IsVisible="False" Classes="glass-panel" Padding="0">
            <ContentControl Name="PunkBusterContent" />
          </Border>

          <!-- Tab 16: Text Chat Moderation -->
          <Border Name="Tab16" IsVisible="False" Classes="glass-panel" Padding="0">
            <ContentControl Name="TextChatModerationContent" />
          </Border>

        </Panel>
      </Border>
      </Panel>

    </DockPanel>
  </DockPanel>
</Window>
