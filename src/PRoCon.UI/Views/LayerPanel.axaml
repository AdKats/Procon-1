<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="PRoCon.UI.Views.LayerPanel"
             x:CompileBindings="False"
             Background="{DynamicResource BackgroundBrush}">

  <ScrollViewer>
    <StackPanel Spacing="12" Margin="16">

      <!-- Layer Status Hero -->
      <Border Background="{DynamicResource SurfaceBrush}"
              BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
              CornerRadius="3" Padding="20">
        <Grid ColumnDefinitions="*,Auto">
          <StackPanel Spacing="6">
            <StackPanel Orientation="Horizontal" Spacing="10">
              <TextBlock Text="Layer Service" FontSize="18" FontWeight="Bold"
                         Foreground="{DynamicResource TextPrimaryBrush}" />
              <Border Name="LayerProtocolBadge" Background="{DynamicResource PrimaryBrush}"
                      CornerRadius="4" Padding="8,3" VerticalAlignment="Center">
                <TextBlock Text="SignalR WebSocket" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource BackgroundBrush}" />
              </Border>
            </StackPanel>
            <TextBlock Text="The layer allows remote admin connections to manage this server through PRoCon."
                       Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" TextWrapping="Wrap" />
          </StackPanel>

          <!-- Status indicator -->
          <Border Grid.Column="1" Width="70" Height="70" CornerRadius="35"
                  Background="{DynamicResource BackgroundBrush}"
                  BorderBrush="{DynamicResource BorderBrush}" BorderThickness="2"
                  HorizontalAlignment="Center" VerticalAlignment="Center">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
              <Ellipse Name="LayerStatusIndicator" Width="12" Height="12"
                       Fill="{DynamicResource ErrorBrush}" HorizontalAlignment="Center" />
              <TextBlock Name="LayerStatusText" Text="Offline" FontSize="9"
                         Foreground="{DynamicResource TextSecondaryBrush}"
                         HorizontalAlignment="Center" Margin="0,4,0,0" />
            </StackPanel>
          </Border>
        </Grid>
      </Border>

      <!-- Control & Configuration -->
      <Grid ColumnDefinitions="*,*">
        <!-- Enable/Disable -->
        <Border Grid.Column="0" Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                CornerRadius="3" Padding="16" Margin="0,0,6,0">
          <StackPanel Spacing="10">
            <TextBlock Text="CONTROL" FontSize="10" FontWeight="Bold"
                       Foreground="{DynamicResource TextSecondaryBrush}" />
            <CheckBox Name="LayerEnabledCheck" Content="Enable Layer Service"
                      Foreground="{DynamicResource TextPrimaryBrush}"
                      Click="OnLayerEnabledToggle" />
            <TextBlock Text="When enabled, remote admin clients can connect via SignalR WebSocket to manage the game server."
                       Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"
                       TextWrapping="Wrap" />
          </StackPanel>
        </Border>

        <!-- Configuration -->
        <Border Grid.Column="1" Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                CornerRadius="3" Padding="16" Margin="6,0,0,0">
          <StackPanel Spacing="8">
            <TextBlock Text="CONFIGURATION" FontSize="10" FontWeight="Bold"
                       Foreground="{DynamicResource TextSecondaryBrush}" />
            <Grid ColumnDefinitions="100,*" RowDefinitions="Auto,Auto">
              <TextBlock Grid.Row="0" Grid.Column="0" Text="Port:"
                         Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" />
              <TextBox Grid.Row="0" Grid.Column="1" Name="LayerPortInput" Width="100"
                       HorizontalAlignment="Left"
                       Background="{DynamicResource InputBackgroundBrush}"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       BorderBrush="{DynamicResource BorderBrush}" Margin="0,2" />
              <TextBlock Grid.Row="1" Grid.Column="0" Text="Bind Address:"
                         Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="0,6,0,0" />
              <TextBox Grid.Row="1" Grid.Column="1" Name="LayerBindingAddressInput"
                       Background="{DynamicResource InputBackgroundBrush}"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       BorderBrush="{DynamicResource BorderBrush}" Margin="0,6,0,2" />
            </Grid>
            <Button Content="Apply" HorizontalAlignment="Left"
                    Background="{DynamicResource ButtonPrimaryBrush}"
                    Foreground="{DynamicResource ButtonPrimaryTextBrush}"
                    Padding="14,5" CornerRadius="4" FontSize="12"
                    Click="OnApplyLayerConfig" />
          </StackPanel>
        </Border>
      </Grid>

      <!-- Connected Clients -->
      <Border Background="{DynamicResource SurfaceBrush}"
              BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
              CornerRadius="3" Padding="16">
        <DockPanel>
          <DockPanel DockPanel.Dock="Top" Margin="0,0,0,8">
            <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" Spacing="8">
              <TextBlock Text="CONNECTED CLIENTS" FontSize="10" FontWeight="Bold"
                         Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" />
              <Border Name="ClientCountBadge" Background="{DynamicResource PrimaryBrush}"
                      CornerRadius="3" Padding="8,2" VerticalAlignment="Center">
                <TextBlock Name="ClientCountText" Text="0" FontSize="10" FontWeight="Bold"
                           Foreground="{DynamicResource BackgroundBrush}" />
              </Border>
            </StackPanel>
            <Button Content="Refresh" HorizontalAlignment="Right"
                    Background="{DynamicResource ButtonSecondaryBrush}"
                    Foreground="{DynamicResource ButtonSecondaryTextBrush}"
                    Padding="10,4" CornerRadius="4" FontSize="11"
                    Click="OnRefreshClients" />
          </DockPanel>
          <ListBox Name="LayerClientsList" MinHeight="80"
                   Background="Transparent"
                   Foreground="{DynamicResource TextPrimaryBrush}" FontSize="12">
            <ListBox.ItemTemplate>
              <DataTemplate>
                <StackPanel Orientation="Horizontal" Spacing="8" Margin="4,3">
                  <Ellipse Width="6" Height="6" Fill="#00ff88" VerticalAlignment="Center" />
                  <TextBlock Text="{Binding}" FontFamily="Consolas, Courier New, monospace" />
                </StackPanel>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </DockPanel>
      </Border>

      <!-- Connection Info -->
      <Border Background="{DynamicResource SurfaceBrush}"
              BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
              CornerRadius="3" Padding="16">
        <StackPanel Spacing="6">
          <TextBlock Text="CONNECTION INFO" FontSize="10" FontWeight="Bold"
                     Foreground="{DynamicResource TextSecondaryBrush}" />
          <TextBlock Name="LayerConnectionInfo" Text="Layer is not running."
                     Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"
                     FontFamily="Consolas, Courier New, monospace" TextWrapping="Wrap" />
        </StackPanel>
      </Border>

      <!-- Status -->
      <TextBlock Name="LayerStatusMessage" Text=""
                 Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" />

    </StackPanel>
  </ScrollViewer>
</UserControl>
