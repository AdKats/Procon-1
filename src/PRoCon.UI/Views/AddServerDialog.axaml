<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="PRoCon.UI.Views.AddServerDialog"
        x:CompileBindings="False"
        Title="Add Server"
        Width="460" Height="420"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundBrush}">

  <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="3" Padding="24" Margin="16">
    <StackPanel Spacing="14">
      <TextBlock Name="DialogTitle" Text="Add Game Server" FontSize="18" FontWeight="Bold"
                 Foreground="{DynamicResource PrimaryBrush}" />

      <!-- Connection type toggle -->
      <StackPanel Orientation="Horizontal" Spacing="4">
        <Button Name="ModeDirectBtn" Content="Direct RCON" Padding="14,6" CornerRadius="4"
                FontSize="12" FontWeight="SemiBold"
                Background="{DynamicResource PrimaryBrush}" Foreground="{DynamicResource BackgroundBrush}"
                Click="OnModeDirectClick" />
        <Button Name="ModeLayerBtn" Content="PRoCon Layer" Padding="14,6" CornerRadius="4"
                FontSize="12"
                Background="{DynamicResource ButtonSecondaryBrush}"
                Foreground="{DynamicResource ButtonSecondaryTextBrush}"
                Click="OnModeLayerClick" />
      </StackPanel>

      <TextBlock Name="DialogDescription"
                 Text="Connect directly to a game server's RCON port."
                 Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" TextWrapping="Wrap" />

      <Grid ColumnDefinitions="90,*" RowDefinitions="Auto,Auto,Auto,Auto" Margin="0,4,0,0">
        <TextBlock Grid.Row="0" Grid.Column="0" Text="Host:"
                   Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="0,4" />
        <TextBox Grid.Row="0" Grid.Column="1" Name="HostInput"
                 Watermark="e.g. 65.75.210.194"
                 Background="{DynamicResource InputBackgroundBrush}"
                 Foreground="{DynamicResource TextPrimaryBrush}"
                 BorderBrush="{DynamicResource BorderBrush}" Margin="0,4" />

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Port:"
                   Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="0,4" />
        <TextBox Grid.Row="1" Grid.Column="1" Name="PortInput"
                 Watermark="e.g. 47300"
                 Background="{DynamicResource InputBackgroundBrush}"
                 Foreground="{DynamicResource TextPrimaryBrush}"
                 BorderBrush="{DynamicResource BorderBrush}" Margin="0,4" />

        <!-- Username (layer mode only) -->
        <TextBlock Grid.Row="2" Grid.Column="0" Name="UsernameLabel" Text="Username:"
                   Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="0,4"
                   IsVisible="False" />
        <TextBox Grid.Row="2" Grid.Column="1" Name="UsernameInput"
                 Watermark="PRoCon account username"
                 Background="{DynamicResource InputBackgroundBrush}"
                 Foreground="{DynamicResource TextPrimaryBrush}"
                 BorderBrush="{DynamicResource BorderBrush}" Margin="0,4"
                 IsVisible="False" />

        <TextBlock Grid.Row="3" Grid.Column="0" Text="Password:"
                   Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="0,4" />
        <TextBox Grid.Row="3" Grid.Column="1" Name="PasswordInput"
                 PasswordChar="*"
                 Watermark="RCON password"
                 Background="{DynamicResource InputBackgroundBrush}"
                 Foreground="{DynamicResource TextPrimaryBrush}"
                 BorderBrush="{DynamicResource BorderBrush}" Margin="0,4" />
      </Grid>

      <TextBlock Name="ErrorText" Text="" Foreground="{DynamicResource ErrorBrush}"
                 FontSize="11" IsVisible="False" />

      <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" Margin="0,8,0,0">
        <Button Content="Cancel"
                Background="{DynamicResource ButtonSecondaryBrush}"
                Foreground="{DynamicResource ButtonSecondaryTextBrush}"
                Padding="16,8" CornerRadius="4"
                Click="OnCancel" />
        <Button Name="AddButton" Content="Add &amp; Connect"
                Background="{DynamicResource ButtonPrimaryBrush}"
                Foreground="{DynamicResource ButtonPrimaryTextBrush}"
                Padding="16,8" CornerRadius="4"
                Click="OnAdd" />
      </StackPanel>
    </StackPanel>
  </Border>
</Window>
